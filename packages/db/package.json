{
  "name": "@smartsend/db",
  "private": true,
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "node ../../scripts/build-workspace-package.mjs",
    "db:check": "tsx src/scripts/check-connection.ts",
    "db:generate": "tsc -p tsconfig.drizzle.json && drizzle-kit generate --config drizzle.config.mjs",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.mjs",
    "db:test:prepare": "tsx src/scripts/prepare-test-db.ts",
    "db:seed:local": "tsx src/scripts/seed-local-dev.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@smartsend/shared": "file:../shared",
    "drizzle-orm": "^0.36.4",
    "dotenv": "^16.4.7",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.1"
  }
}
